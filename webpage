  ════════════════════════════════════════════════════════════ */
  function postedLabel(d) {
    if (d <= 0)  return 'Posted today';
    if (d === 1) return 'Posted 1 day ago';
    if (d < 7)   return `Posted ${d} days ago`;
    if (d < 14)  return 'Posted 1 week ago';
    if (d < 21)  return 'Posted 2 weeks ago';
    if (d < 30)  return `Posted ${Math.floor(d/7)} weeks ago`;
    return `Posted ${Math.floor(d/30)}mo ago`;
  }
  function allIndustries(data) {
    const s = new Set(['All']);
    data.forEach(d => (d.industries||[]).forEach(i => { if (i !== 'All') s.add(i); }));
    return [...s];
  }
  function eligChips(item) {
    const chips = [];
    if (item.gradYears && item.gradYears.length) {
      const yrs = item.gradYears;
      const label = yrs.length === 1 ? `Class of ${yrs[0]}` : `Class of ${yrs[0]}–${yrs[yrs.length-1]}`;
      chips.push(`<span class="elig-chip elig-year"><svg viewBox="0 0 10 10" fill="none"><path d="M1 7.5L5 2.5 9 7.5" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/></svg>${label}</span>`);
    }
    if (item.citizenRequired === true) {
      chips.push(`<span class="elig-chip elig-req"><svg viewBox="0 0 10 10" fill="currentColor"><circle cx="5" cy="5" r="3.5"/></svg>US Citizen required</span>`);
    } else if (item.citizenRequired === false) {
      chips.push(`<span class="elig-chip elig-ok"><svg viewBox="0 0 10 10" fill="none"><path d="M1.5 5l2.5 2.5 5-5" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/></svg>Intl. students OK</span>`);
    }
    (item.additionalEligibility||[]).forEach(e => {
      chips.push(`<span class="elig-chip elig-special">${e}</span>`);
    });
    return chips.join('');
  }

