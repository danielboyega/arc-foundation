  function makePills(items, containerId, onChange) {
    const c = document.getElementById(containerId);
    items.forEach((item, i) => {
      const b = document.createElement('button');
      b.className = 'pill' + (i === 0 ? ' on' : '');
      b.textContent = item;
      b.addEventListener('click', () => {
        c.querySelectorAll('.pill').forEach(p => p.classList.remove('on'));
        b.classList.add('on'); onChange();
      });
      c.appendChild(b);
    });
  }
  function getActive(id) { return document.querySelector(`#${id} .pill.on`)?.textContent || 'All'; }

