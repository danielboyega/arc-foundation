<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>ARC Foundation — Accelerating Rising Careers</title>
  <meta name="description" content="ARC Foundation is a student-founded nonprofit providing mentorship, scholarships, and leadership development to ambitious students building their careers.">
  <meta name="theme-color" content="#0C1A3A">
  <meta name="msapplication-TileColor" content="#0C1A3A">
  <meta name="msapplication-TileImage" content="faviconhead.png">

  <!-- Favicons — all sizes for premium browser/OS presentation -->
  <link rel="icon"             type="image/png" sizes="192x192" href="faviconhead.png">
  <link rel="icon"             type="image/png" sizes="96x96"   href="faviconhead.png">
  <link rel="icon"             type="image/png" sizes="32x32"   href="faviconhead.png">
  <link rel="icon"             type="image/png" sizes="16x16"   href="faviconhead.png">
  <link rel="apple-touch-icon" sizes="180x180"                  href="faviconhead.png">

  <!-- Preload critical above-fold assets -->
  <link rel="preload" as="image" href="ARCLOGO-BLACK.png">
  <link rel="preload" as="image" href="ARCLOGO-WHITE.png">

  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@1,700&family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet">

  <style>
    :root {
      --navy:     #0C1A3A;
      --navy-2:   #152647;
      --gold:     #C9972A;
      --gold-lt:  #E8B84B;
      --gold-pl:  #FDF5E0;
      --blue-acc: #1A56DB;
      --white:    #FFFFFF;
      --off:      #F7F7F5;
      --g100:     #E8E8E5;
      --g400:     #9E9E9A;
      --muted:    #68685E;
      --dark:     #111110;
      --ease:     cubic-bezier(.4,0,.2,1);
      --ease-out: cubic-bezier(0,0,.2,1);
      --r:12px; --rL:20px; --rXL:28px;
    }
    *,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
    html{scroll-behavior:smooth;font-size:16px;-webkit-text-size-adjust:100%}
    body{font-family:'Inter',sans-serif;color:var(--dark);background:var(--white);overflow-x:hidden;-webkit-font-smoothing:antialiased;text-rendering:optimizeSpeed}
    h1,h2,h3,h4{line-height:1.1}
    p{line-height:1.75}
    a{color:inherit;text-decoration:none}
    img{max-width:100%;display:block}
    button{cursor:pointer;font-family:'Inter',sans-serif;border:none;outline:none}
    .container{width:100%;max-width:1160px;margin:0 auto;padding:0 40px}

    /* ── Buttons ── */
    .btn{display:inline-flex;align-items:center;gap:8px;padding:13px 26px;border-radius:50px;font-size:.9375rem;font-weight:600;transition:all .2s var(--ease);white-space:nowrap;cursor:pointer}
    .btn-gold{background:var(--gold);color:#fff}
    .btn-gold:hover{background:var(--gold-lt);transform:translateY(-2px);box-shadow:0 8px 20px rgba(201,151,42,.3)}
    .btn-dark{background:var(--navy);color:#fff}
    .btn-dark:hover{background:var(--navy-2);transform:translateY(-2px)}
    .btn-outline{background:transparent;color:var(--dark);border:1.5px solid var(--g100)}
    .btn-outline:hover{border-color:var(--dark)}
    .btn-outline-w{background:transparent;color:#fff;border:1.5px solid rgba(255,255,255,.3)}
    .btn-outline-w:hover{border-color:#fff;background:rgba(255,255,255,.08)}
    .btn-glow{position:relative;overflow:hidden;background:transparent;border:1.5px solid rgba(255,255,255,.3);color:#fff}
    .btn-glow::before{content:'';position:absolute;inset:0;border-radius:inherit;background:linear-gradient(135deg,var(--blue-acc),var(--gold));opacity:0;transition:opacity .25s}
    .btn-glow span{position:relative;z-index:1}
    .btn-glow:hover::before{opacity:1}
    .btn-glow:hover{border-color:transparent;box-shadow:0 0 24px rgba(26,86,219,.4),0 0 48px rgba(201,151,42,.25);transform:translateY(-2px)}
    .btn-glow-lgt{position:relative;overflow:hidden;background:transparent;border:1.5px solid var(--g100);color:var(--dark)}
    .btn-glow-lgt::before{content:'';position:absolute;inset:0;border-radius:inherit;background:linear-gradient(135deg,var(--blue-acc),var(--gold));opacity:0;transition:opacity .25s}
    .btn-glow-lgt span{position:relative;z-index:1}
    .btn-glow-lgt:hover::before{opacity:1}
    .btn-glow-lgt:hover{border-color:transparent;color:#fff;box-shadow:0 0 24px rgba(26,86,219,.35);transform:translateY(-2px)}

    /* ── Loader ── */
    #loader{position:fixed;inset:0;background:var(--navy);display:flex;align-items:center;justify-content:center;z-index:9999;transition:opacity .6s var(--ease),visibility .6s}
    #loader.hidden{opacity:0;visibility:hidden;pointer-events:none}
    .loader-wrap{position:relative;width:128px;height:128px}
    .loader-ghost{position:absolute;inset:0;width:100%;height:100%;object-fit:contain;opacity:.15}
    .loader-fill{position:absolute;inset:0;overflow:hidden;animation:fillPulse 1.5s ease-in-out infinite}
    .loader-fill img{width:100%;height:100%;object-fit:contain}
    .loader-wrap{position:relative;width:128px;height:128px;animation:glowPulse 1.5s ease-in-out infinite}
    @keyframes fillPulse{
      0%{clip-path:inset(100% 0 0 0)}
      60%{clip-path:inset(0% 0 0 0)}
      85%{clip-path:inset(0% 0 0 0)}
      100%{clip-path:inset(100% 0 0 0)}
    }
    @keyframes glowPulse{
      0%,100%{filter:none}
      60%,85%{filter:drop-shadow(0 0 10px rgba(255,255,255,.95)) drop-shadow(0 0 22px rgba(255,255,255,.6))}
    }

    /* ── Nav ── */
    #nav{position:fixed;top:0;left:0;right:0;z-index:900;background:rgba(255,255,255,.97);border-bottom:1px solid var(--g100);transition:box-shadow .25s}
    #nav.scrolled{box-shadow:0 2px 20px rgba(0,0,0,.07)}
    .nav-inner{display:flex;align-items:center;height:72px}
    .nav-logo img{height:60px;width:auto;display:block}
    .nav-links{display:flex;list-style:none;gap:2px;margin-left:auto;margin-right:14px}
    .nav-links a{padding:8px 13px;font-size:.875rem;font-weight:500;color:var(--muted);border-radius:8px;transition:all .18s}
    .nav-links a:hover,.nav-links a.active{color:var(--dark);background:var(--off)}
    #hamburger{display:none;flex-direction:column;gap:5px;padding:8px;background:none;margin-left:auto}
    #hamburger span{width:22px;height:2px;background:var(--dark);border-radius:2px;transition:all .25s;display:block}
    #mobile-menu{display:none;position:fixed;top:72px;left:0;right:0;background:#fff;border-bottom:1px solid var(--g100);padding:10px 20px 18px;flex-direction:column;gap:2px;z-index:899}
    #mobile-menu.open{display:flex}
    #mobile-menu a{padding:12px 14px;font-weight:500;border-radius:8px}
    #mobile-menu a:hover{background:var(--off)}

    /* ── Scroll Animations ── */
    @media(prefers-reduced-motion:no-preference){
      .fade-up{opacity:0;transform:translateY(22px);transition:opacity .6s var(--ease-out),transform .6s var(--ease-out);will-change:opacity,transform}
      .fade-up.d1{transition-delay:.07s}
      .fade-up.d2{transition-delay:.14s}
      .fade-up.d3{transition-delay:.21s}
      .fade-up.d4{transition-delay:.28s}
    }
    .fade-up.visible{opacity:1;transform:none}

    /* ── Shared ── */
    .overline{display:block;font-size:11px;font-weight:700;letter-spacing:3px;text-transform:uppercase;color:var(--gold);margin-bottom:14px}
    .sh2{font-size:clamp(1.85rem,4vw,2.75rem);font-weight:900;letter-spacing:-.025em;color:var(--dark);margin-bottom:14px}
    .sh2.light{color:#fff}
    .sub{font-size:1.0625rem;color:var(--muted);max-width:520px;line-height:1.75}
    .sec{padding:100px 0}

    /* ═══ HERO ═══ */
    #hero{padding:148px 0 100px;background:var(--white);text-align:center}
    .hero-h1{font-family:'Inter',sans-serif;font-size:clamp(2.9rem,7vw,5.5rem);font-weight:900;line-height:1.04;letter-spacing:-.035em;color:var(--dark);max-width:820px;margin:0 auto 26px}
    .hero-h1 em{font-style:italic;font-family:'Playfair Display',serif;color:var(--gold)}
    .hero-sub{font-size:1.0625rem;color:var(--muted);max-width:460px;margin:0 auto 36px;line-height:1.75}
    .hero-actions{display:flex;gap:10px;justify-content:center;flex-wrap:wrap}
    .hero-howard{font-size:11px;color:var(--g400);margin-top:18px;letter-spacing:1.5px;text-transform:uppercase}

    /* ═══ MISSION ═══ */
    #mission{padding:100px 0;background:var(--white)}
    .mission-top{display:grid;grid-template-columns:1fr 1fr;gap:60px;align-items:end;margin-bottom:64px}
    .mission-top h2{font-size:clamp(1.9rem,4vw,3rem);font-weight:900;letter-spacing:-.028em;line-height:1.1}
    .mission-top p{font-size:1.0625rem;color:var(--muted);line-height:1.8}
    .pillars{border-top:1px solid var(--g100)}
    .pillar-row{display:grid;grid-template-columns:64px 1fr 1fr;gap:36px;align-items:start;padding:40px 0;border-bottom:1px solid var(--g100);border-radius:var(--rL);transition:background .18s}
    .pillar-row:hover{background:var(--off);margin:0 -40px;padding-left:40px;padding-right:40px}
    .pillar-num{font-size:.7rem;font-weight:700;color:var(--g400);letter-spacing:2px;padding-top:5px}
    .pillar-left h3{font-size:1.5rem;font-weight:900;letter-spacing:-.018em;margin-bottom:8px}
    .pillar-tag{display:inline-flex;align-items:center;background:var(--gold-pl);color:var(--gold);border-radius:50px;font-size:10px;font-weight:700;letter-spacing:2px;text-transform:uppercase;padding:4px 12px}
    .pillar-right{padding-top:4px}
    .pillar-right p{font-size:.9375rem;color:var(--muted);line-height:1.8}
    @media(max-width:760px){.pillar-row{grid-template-columns:44px 1fr}.pillar-right{grid-column:2}.mission-top{grid-template-columns:1fr;gap:20px}}

    /* ═══ STORY ═══ */
    #story{padding:100px 0;background:var(--navy);color:#fff;position:relative;overflow:hidden}
    #story::before{content:'';position:absolute;top:-200px;right:-200px;width:700px;height:700px;border-radius:50%;background:radial-gradient(circle,rgba(201,151,42,.09) 0%,transparent 70%);pointer-events:none}
    .story-layout{display:grid;grid-template-columns:5fr 4fr;gap:72px;align-items:stretch;position:relative}
    .story-year{display:inline-block;background:var(--gold);color:#fff;padding:5px 16px;border-radius:50px;font-size:11px;font-weight:700;letter-spacing:2px;text-transform:uppercase;margin-bottom:26px}
    .story-layout h2{font-size:clamp(1.85rem,3.8vw,2.9rem);font-weight:900;letter-spacing:-.025em;margin-bottom:30px;line-height:1.1}
    .story-body p{color:rgba(255,255,255,.7);font-size:1rem;line-height:1.85;margin-bottom:18px}
    .story-body p:last-child{margin-bottom:0}
    .story-body strong{color:rgba(255,255,255,.95)}
    .story-aside{display:flex;flex-direction:column;gap:12px;height:100%}
    .story-card{background:rgba(255,255,255,.06);border:1px solid rgba(255,255,255,.1);border-radius:var(--rXL);padding:24px 26px;display:flex;flex-direction:column}
    .story-card .sc-topic{font-size:10px;font-weight:700;letter-spacing:2px;text-transform:uppercase;color:rgba(255,255,255,.4);margin-bottom:10px}
    .story-card .sc-num{font-size:2.1rem;font-weight:900;letter-spacing:-.03em;color:var(--gold-lt);line-height:1;margin-bottom:8px}
    .story-card .sc-label{font-size:.875rem;color:rgba(255,255,255,.55);font-weight:500;line-height:1.55;flex:1}
    .story-card .sc-source{font-size:9px;color:rgba(255,255,255,.25);margin-top:10px;text-align:right;font-style:italic}
    .story-card.accent{background:var(--gold);border-color:transparent}
    .story-card.accent .sc-topic{color:rgba(255,255,255,.7)}
    .story-card.accent .sc-num{color:#fff}
    .story-card.accent .sc-label{color:rgba(255,255,255,.85)}
    .story-card.accent .sc-source{color:rgba(255,255,255,.45)}
    .story-photo{border-radius:var(--rXL);overflow:hidden;flex:1;min-height:140px;position:relative;border:1px solid rgba(255,255,255,.1)}
    .story-photo img{width:100%;height:100%;object-fit:cover;display:block}
    .story-photo-cap{position:absolute;bottom:0;left:0;right:0;padding:14px 16px 12px;background:linear-gradient(to top,rgba(12,26,58,.75),transparent);color:rgba(255,255,255,.7);font-size:11px;font-weight:600;letter-spacing:.5px}
    @media(max-width:860px){.story-layout{grid-template-columns:1fr;gap:44px}.story-aside{height:auto}.story-photo{min-height:200px}}

    /* ═══ FOUNDERS ═══ */
    #founders{padding:100px 0;background:#fff}
    .founders-title-row{display:flex;align-items:flex-end;justify-content:space-between;margin-bottom:64px;flex-wrap:wrap;gap:16px}
    .founders-big-h{font-size:clamp(3rem,8vw,7rem);font-weight:900;letter-spacing:-.045em;line-height:.9}
    .founders-tagline{font-size:1rem;color:var(--muted);max-width:300px;line-height:1.7;padding-bottom:6px}
    .founders-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:28px}
    .founder-card{display:flex;flex-direction:column;cursor:pointer}
    .founder-photo{width:100%;aspect-ratio:3/4;border-radius:22px;overflow:hidden;background:var(--off);margin-bottom:20px;position:relative}
    .founder-photo img{width:100%;height:100%;object-fit:cover;object-position:center top;display:block;transition:transform .5s var(--ease)}
    .founder-card:hover .founder-photo img{transform:scale(1.04)}
    .founder-overlay{position:absolute;inset:0;background:linear-gradient(to top,rgba(12,26,58,.6) 0%,transparent 55%);opacity:0;transition:opacity .3s;display:flex;align-items:flex-end;padding:24px}
    .founder-card:hover .founder-overlay{opacity:1}
    .founder-view-cta{color:#fff;font-size:.8125rem;font-weight:700;letter-spacing:.5px;display:flex;align-items:center;gap:6px}
    .founder-view-cta svg{width:14px;height:14px;transition:transform .2s}
    .founder-card:hover .founder-view-cta svg{transform:translateX(3px)}
    .founder-name{font-size:1.2rem;font-weight:800;letter-spacing:-.01em;display:block;margin-bottom:3px;transition:color .18s}
    .founder-card:hover .founder-name{color:var(--gold)}
    .founder-role{font-size:10px;font-weight:700;letter-spacing:2px;text-transform:uppercase;color:var(--gold)}
    @media(max-width:760px){.founders-grid{grid-template-columns:1fr;max-width:320px;margin:0 auto}.founders-title-row{flex-direction:column;align-items:flex-start}}

    /* ═══ FOUNDER PANEL (slide-in page) ═══ */
    .fp-overlay{position:fixed;inset:0;z-index:1100;background:rgba(10,18,40,.5);backdrop-filter:blur(6px);opacity:0;visibility:hidden;transition:opacity .35s var(--ease),visibility .35s}
    .fp-overlay.open{opacity:1;visibility:visible}
    .fp-panel{position:fixed;top:0;right:0;bottom:0;width:min(680px,100vw);background:#fff;z-index:1101;transform:translateX(100%);transition:transform .42s cubic-bezier(.32,0,.15,1);overflow-y:auto;display:flex;flex-direction:column}
    .fp-overlay.open .fp-panel{transform:none}
    .fp-panel-inner{display:grid;grid-template-columns:200px 1fr;min-height:100%;align-items:start}
    .fp-photo-col{position:sticky;top:0;height:100vh;overflow:hidden;background:var(--off)}
    .fp-photo-col img{width:100%;height:100%;object-fit:cover;object-position:center top;display:block}
    .fp-content{padding:52px 40px 60px;display:flex;flex-direction:column}
    .fp-close{position:fixed;top:20px;right:20px;z-index:1102;width:40px;height:40px;border-radius:50%;background:#fff;border:1px solid var(--g100);display:flex;align-items:center;justify-content:center;cursor:pointer;font-size:18px;color:var(--muted);transition:all .18s;box-shadow:0 2px 12px rgba(0,0,0,.1)}
    .fp-close:hover{background:var(--off);color:var(--dark);transform:scale(1.08)}
    .fp-overline{font-size:10px;font-weight:700;letter-spacing:3px;text-transform:uppercase;color:var(--gold);margin-bottom:10px}
    .fp-name{font-size:clamp(1.5rem,3vw,2.25rem);font-weight:900;letter-spacing:-.025em;line-height:1.1;margin-bottom:6px}
    .fp-title{font-size:.875rem;font-weight:700;color:var(--muted);margin-bottom:32px;padding-bottom:32px;border-bottom:1px solid var(--g100)}
    .fp-bio{font-size:.9375rem;color:var(--muted);line-height:1.8}
    .fp-bio p+p{margin-top:16px}
    .bio-highlight{color:var(--gold);font-weight:700;text-shadow:0 0 20px rgba(201,151,42,.28)}
    .bio-role{font-weight:700;color:var(--muted)}
    @media(max-width:600px){.fp-panel-inner{grid-template-columns:1fr}.fp-photo-col{position:relative;height:280px;width:100%}.fp-content{padding:32px 24px 48px}}

    /* ═══ IMPACT ═══ */
    #impact{padding:100px 0;background:var(--navy);position:relative;overflow:hidden}
    #impact::before{content:'';position:absolute;top:50%;left:50%;transform:translate(-50%,-50%);width:700px;height:500px;background:radial-gradient(ellipse,rgba(201,151,42,.13) 0%,transparent 70%);pointer-events:none}
    .impact-intro{display:grid;grid-template-columns:1fr 1fr;gap:56px;align-items:center;margin-bottom:56px;position:relative}
    .impact-intro h2{font-size:clamp(1.85rem,3.8vw,2.9rem);font-weight:900;letter-spacing:-.025em;line-height:1.08;color:#fff}
    .impact-intro p{font-size:1rem;color:rgba(255,255,255,.55);line-height:1.8}
    .impact-intro .growing{color:var(--gold-lt);font-weight:700}
    .impact-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:2px;position:relative}
    .impact-cell{background:rgba(255,255,255,.04);border:1px solid rgba(255,255,255,.07);padding:40px 20px;text-align:center;transition:background .2s,border-color .2s}
    .impact-cell:first-child{border-radius:var(--rXL) 0 0 var(--rXL)}
    .impact-cell:last-child{border-radius:0 var(--rXL) var(--rXL) 0}
    .impact-cell:hover{background:rgba(255,255,255,.07);border-color:rgba(201,151,42,.3)}
    .ic-num{font-size:3.25rem;font-weight:900;letter-spacing:-.03em;line-height:1;margin-bottom:8px;background:linear-gradient(135deg,var(--gold-lt) 0%,var(--gold) 100%);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;transition:transform .6s var(--ease)}
    .ic-num.glow{transform:scale(1.06)}
    .impact-cell.glow{background:rgba(201,151,42,.1)!important;border-color:rgba(201,151,42,.45)!important;box-shadow:0 0 0 1px rgba(201,151,42,.2),0 0 32px rgba(201,151,42,.18)}
    .ic-lbl{font-size:.75rem;font-weight:600;color:rgba(255,255,255,.45);text-transform:uppercase;letter-spacing:1.5px;line-height:1.4}
    @media(max-width:860px){.impact-intro{grid-template-columns:1fr;gap:20px}}
    @media(max-width:640px){.impact-grid{grid-template-columns:repeat(2,1fr)}.impact-cell:first-child{border-radius:var(--rXL) 0 0 0}.impact-cell:nth-child(2){border-radius:0 var(--rXL) 0 0}.impact-cell:nth-child(3){border-radius:0 0 0 var(--rXL)}.impact-cell:last-child{border-radius:0 0 var(--rXL) 0}}

    /* ═══ SECTION STACK OVERLAP ═══ */
    #story{border-radius:28px 28px 0 0;position:relative;z-index:2;margin-top:-28px;box-shadow:0 -8px 40px rgba(0,0,0,.12)}
    #founders{border-radius:28px 28px 0 0;position:relative;z-index:3;margin-top:-28px;box-shadow:0 -8px 40px rgba(0,0,0,.06)}

    /* ═══ PILLAR REDESIGN ═══ */
    .pillars{border-top:none;display:flex;flex-direction:column;gap:16px;margin-top:0}
    .pillar-row{display:grid;grid-template-columns:72px 1fr 2fr;gap:28px;align-items:start;padding:32px 28px;border-radius:var(--rL);border:1.5px solid var(--g100);background:#fff;transition:all .22s var(--ease);margin:0!important}
    .pillar-row:hover{transform:translateY(-3px);box-shadow:0 12px 36px rgba(0,0,0,.08)}
    .pillar-row.p-gold{border-left:4px solid var(--gold)}
    .pillar-row.p-blue{border-left:4px solid var(--blue-acc)}
    .pillar-row.p-green{border-left:4px solid #059669}
    .pillar-row:hover.p-gold{box-shadow:0 12px 36px rgba(201,151,42,.15)}
    .pillar-row:hover.p-blue{box-shadow:0 12px 36px rgba(26,86,219,.12)}
    .pillar-row:hover.p-green{box-shadow:0 12px 36px rgba(5,150,105,.12)}
    .pillar-icon{width:52px;height:52px;border-radius:14px;display:flex;align-items:center;justify-content:center;flex-shrink:0}
    .pillar-icon svg{width:26px;height:26px}
    .pillar-icon.ic-gold{background:var(--gold-pl)}
    .pillar-icon.ic-blue{background:rgba(26,86,219,.1)}
    .pillar-icon.ic-green{background:rgba(5,150,105,.1)}
    .pillar-num{display:none}
    .pillar-left h3{font-size:1.4rem;font-weight:900;letter-spacing:-.018em;margin-bottom:8px}
    .pillar-tag{display:inline-flex;align-items:center;background:var(--gold-pl);color:var(--gold);border-radius:50px;font-size:10px;font-weight:700;letter-spacing:2px;text-transform:uppercase;padding:4px 12px}
    .pillar-tag.t-blue{background:rgba(26,86,219,.1);color:var(--blue-acc)}
    .pillar-tag.t-green{background:rgba(5,150,105,.1);color:#059669}
    .pillar-right{padding-top:4px}
    .pillar-right p{font-size:.9375rem;color:var(--muted);line-height:1.8}
    @media(max-width:760px){.pillar-row{grid-template-columns:52px 1fr}.pillar-right{grid-column:2}.mission-top{grid-template-columns:1fr;gap:20px}}

    /* ═══ FOUNDER BIO HIGHLIGHTS ═══ */
    .bio-highlight{color:var(--gold);font-weight:700;text-shadow:0 0 18px rgba(201,151,42,.25)}
    .bio-role{font-weight:700;color:var(--muted);font-size:.8125rem;letter-spacing:.5px}

    /* ═══ GET INVOLVED CARDS ═══ */
    .inv-cards{display:grid;grid-template-columns:1fr 1fr;gap:16px;margin-top:40px}
    .inv-card{background:#fff;border:1.5px solid var(--g100);border-radius:var(--rXL);padding:32px;display:flex;flex-direction:column;gap:16px;transition:all .22s var(--ease)}
    .inv-card:hover{border-color:var(--gold);transform:translateY(-3px);box-shadow:0 12px 36px rgba(0,0,0,.09)}
    .inv-card-icon{width:48px;height:48px;border-radius:12px;background:var(--gold-pl);display:flex;align-items:center;justify-content:center;flex-shrink:0}
    .inv-card-icon svg{width:22px;height:22px;color:var(--gold)}
    .inv-card h3{font-size:1.15rem;font-weight:800;letter-spacing:-.012em;margin-bottom:4px}
    .inv-card p{font-size:.875rem;color:var(--muted);line-height:1.6;flex:1}
    @media(max-width:640px){.inv-cards{grid-template-columns:1fr}}

    /* ═══ PROGRAMS ═══ */
    #programs{padding:100px 0;background:var(--off)}
    .progs-grid{display:grid;grid-template-columns:1fr 1fr;gap:20px;margin-top:52px}
    .prog-card{border-radius:var(--rXL);overflow:hidden;position:relative;display:flex;flex-direction:column}
    .prog-card.scholars{background:var(--navy);color:#fff}
    .prog-card.fellows{background:#fff;border:1px solid var(--g100)}
    .prog-photo{height:220px;position:relative;overflow:hidden;flex-shrink:0}
    .prog-photo img{width:100%;height:100%;object-fit:cover;display:block;transition:transform .5s var(--ease)}
    .prog-card:hover .prog-photo img{transform:scale(1.04)}
    .prog-photo::after{content:'';position:absolute;inset:0}
    .scholars .prog-photo::after{background:linear-gradient(to bottom,transparent 20%,var(--navy) 100%)}
    .fellows  .prog-photo::after{background:linear-gradient(to bottom,transparent 20%,var(--white) 100%)}
    .prog-content{padding:36px 40px 40px;flex:1;display:flex;flex-direction:column}
    .prog-badge{display:inline-block;padding:4px 14px;border-radius:50px;font-size:10px;font-weight:700;letter-spacing:2px;text-transform:uppercase;margin-bottom:20px;align-self:flex-start}
    .scholars .prog-badge{background:rgba(201,151,42,.2);color:var(--gold-lt)}
    .fellows  .prog-badge{background:rgba(12,26,58,.08);color:var(--navy)}
    .prog-h3{font-size:1.625rem;font-weight:900;letter-spacing:-.018em;margin-bottom:12px}
    .prog-desc{font-size:.9375rem;line-height:1.75;margin-bottom:24px;opacity:.8;flex:1}
    .prog-perks{list-style:none;display:flex;flex-direction:column;gap:10px;margin-bottom:32px}
    .prog-perks li{display:flex;align-items:center;gap:10px;font-size:.9375rem;font-weight:500}
    .pchk{width:18px;height:18px;border-radius:50%;flex-shrink:0;display:flex;align-items:center;justify-content:center}
    .scholars .pchk{background:rgba(201,151,42,.2)}
    .fellows  .pchk{background:rgba(12,26,58,.08)}
    .pchk svg{width:10px;height:10px}
    @media(max-width:760px){.progs-grid{grid-template-columns:1fr}}

    /* ═══ SCHOLARSHIPS ═══ */
    #scholarships{padding:100px 0;background:#fff}
    .schol-layout{display:grid;grid-template-columns:1fr 1fr;gap:72px;align-items:center}
    .schol-tiers{display:flex;flex-direction:column;gap:12px}
    .schol-card{background:var(--off);border:1px solid var(--g100);border-radius:var(--rL);padding:26px 30px;display:flex;align-items:center;gap:22px}
    .schol-card.feat{background:var(--navy);border-color:var(--navy)}
    .sc-amt{font-size:2rem;font-weight:900;letter-spacing:-.025em;color:var(--gold);line-height:1}
    .schol-card.feat .sc-amt{color:var(--gold-lt)}
    .sc-meta{flex:1}
    .sc-per{font-size:.75rem;font-weight:700;text-transform:uppercase;letter-spacing:1.5px;color:var(--muted);margin-bottom:3px}
    .schol-card.feat .sc-per{color:rgba(255,255,255,.4)}
    .sc-rec{font-size:.875rem;font-weight:600;color:var(--dark)}
    .schol-card.feat .sc-rec{color:rgba(255,255,255,.75)}
    .schol-apply{margin-top:24px;padding:26px 30px;background:var(--navy);border-radius:var(--rL);color:#fff;display:flex;align-items:center;gap:18px;flex-wrap:wrap}
    .schol-apply strong{display:block;font-size:1rem;margin-bottom:3px}
    .schol-apply p{font-size:.875rem;color:rgba(255,255,255,.55);flex:1;min-width:140px;margin:0}
    @media(max-width:860px){.schol-layout{grid-template-columns:1fr;gap:44px}}

    /* ═══ FOR STUDENTS ═══ */
    #for-students{padding:100px 0;background:var(--off)}
    .tab-row{display:flex;gap:8px;margin-bottom:28px;flex-wrap:wrap}
    .tab-btn{padding:10px 22px;border-radius:50px;font-size:.875rem;font-weight:600;background:#fff;color:var(--muted);border:1.5px solid var(--g100);transition:all .18s}
    .tab-btn.active{background:var(--navy);color:#fff;border-color:var(--navy)}
    .tab-btn:hover:not(.active){border-color:var(--g400);color:var(--dark)}
    .tab-panel{display:none}
    .tab-panel.active{display:block}
    .filter-group{margin-bottom:16px}
    .filter-label{font-size:11px;font-weight:700;letter-spacing:1.5px;text-transform:uppercase;color:var(--muted);margin-bottom:8px}
    .pills{display:flex;flex-wrap:wrap;gap:6px}
    .pill{padding:6px 15px;border-radius:50px;font-size:.8125rem;font-weight:600;background:#fff;color:var(--muted);border:1.5px solid var(--g100);transition:all .18s;cursor:pointer}
    .pill.on{background:var(--gold);color:#fff;border-color:var(--gold)}
    .pill:hover:not(.on){border-color:var(--g400)}

    /* Resource cards */
    .rc-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(310px,1fr));gap:14px;margin-top:8px}
    .rc{background:#fff;border:1px solid var(--g100);border-radius:var(--rL);transition:all .2s var(--ease);display:flex;flex-direction:column;overflow:hidden}
    .rc:hover{border-color:var(--gold);transform:translateY(-3px);box-shadow:0 10px 30px rgba(0,0,0,.09)}
    .rc.hidden{display:none!important}
    .rc-top{padding:20px 20px 16px}
    .rc-card-hd{display:flex;align-items:center;gap:10px;margin-bottom:14px}
    .rc-org-logo{width:40px;height:40px;border-radius:10px;display:flex;align-items:center;justify-content:center;font-size:10px;font-weight:800;letter-spacing:.3px;color:#fff;flex-shrink:0;text-transform:uppercase;line-height:1}
    .rc-card-hd-meta{flex:1;min-width:0}
    .rc-card-hd-meta .rc-org{margin-bottom:1px;font-size:.8125rem;color:var(--muted);font-weight:600}
    .rc-card-hd-meta .rc-posted{font-size:.75rem;color:var(--g400)}
    .rc-badges{display:flex;align-items:center;gap:6px;margin-bottom:10px;flex-wrap:wrap}
    .rc-type{font-size:10px;font-weight:700;letter-spacing:1.5px;text-transform:uppercase;padding:3px 10px;border-radius:50px;background:var(--gold-pl);color:var(--gold)}
    .rc-paid{font-size:10px;font-weight:700;letter-spacing:1px;text-transform:uppercase;padding:3px 10px;border-radius:50px;background:#ECFDF5;color:#059669}
    .rc-posted{font-size:10px;font-weight:600;color:var(--g400)}
    .rc-name{font-size:.9375rem;font-weight:800;margin-bottom:3px;color:var(--dark)}
    .rc-org{font-size:.8125rem;color:var(--muted);margin-bottom:10px;font-weight:500}
    .rc-desc{font-size:.875rem;color:var(--muted);line-height:1.6;margin-bottom:14px}
    .rc-elig{border-top:1px solid var(--g100);padding:10px 20px;display:flex;flex-wrap:wrap;gap:6px;background:var(--off)}
    .elig-chip{display:inline-flex;align-items:center;gap:5px;font-size:10px;font-weight:600;padding:4px 10px;border-radius:50px;white-space:nowrap}
    .elig-chip svg{width:10px;height:10px;flex-shrink:0}
    .elig-year{background:rgba(12,26,58,.07);color:var(--navy)}
    .elig-ok{background:#ECFDF5;color:#047857}
    .elig-req{background:#FEF2F2;color:#DC2626}
    .elig-special{background:rgba(201,151,42,.12);color:var(--gold)}
    .rc-foot{padding:12px 20px;display:flex;align-items:center;justify-content:space-between;gap:8px;border-top:1px solid var(--g100);flex-wrap:wrap;margin-top:auto}
    .rc-dl{font-size:.8125rem;font-weight:600;color:var(--muted)}
    .rc-dl strong{color:var(--dark)}
    .rc-link{font-size:.8125rem;font-weight:700;color:var(--gold)}
    .rc-link:hover{color:var(--gold-lt)}
    .empty-msg{padding:52px 20px;text-align:center;color:var(--muted);font-size:.9375rem;grid-column:1/-1}

    /* ═══ GET INVOLVED ═══ */
    #get-involved{padding:100px 0;background:#fff}
    .inv-list{margin-top:12px;border-top:1px solid var(--g100)}
    .inv-row{display:grid;grid-template-columns:52px 1fr auto;align-items:center;gap:24px;padding:26px 0;border-bottom:1px solid var(--g100);border-radius:var(--rL);transition:background .18s}
    .inv-row:hover{background:var(--off);margin:0 -40px;padding-left:40px;padding-right:40px}
    .inv-n{font-size:.7rem;font-weight:700;color:var(--g400);letter-spacing:1px}
    .inv-body h3{font-size:1.3rem;font-weight:800;letter-spacing:-.015em;margin-bottom:3px}
    .inv-body p{font-size:.875rem;color:var(--muted);margin:0;line-height:1.6}
    .inv-btn{display:inline-flex;align-items:center;gap:6px;padding:10px 20px;border-radius:50px;font-size:.875rem;font-weight:700;white-space:nowrap;cursor:pointer;flex-shrink:0;transition:all .18s;font-family:'Inter',sans-serif}
    .inv-btn.solid{background:var(--navy);color:#fff;border:none}
    .inv-btn.solid:hover{background:var(--gold);transform:translateY(-2px)}
    .inv-btn.ghost{background:transparent;color:var(--dark);border:1.5px solid var(--g100)}
    .inv-btn.ghost:hover{border-color:var(--navy);background:var(--navy);color:#fff;transform:translateY(-2px)}
    @media(max-width:640px){.inv-row{grid-template-columns:40px 1fr}.inv-btn{display:none}.inv-body h3{font-size:1.1rem}.inv-row:hover{margin:0;padding-left:0;padding-right:0}}

    /* ═══ CTA BANNER ═══ */
    #cta{padding:100px 0;background:var(--navy);text-align:center;position:relative;overflow:hidden}
    #cta::before{content:'';position:absolute;inset:0;background-image:url('ARC BACKGROUND (1).png');background-size:cover;background-position:center;opacity:.07;pointer-events:none}
    #cta .container{position:relative}
    .cta-lbl{font-size:11px;font-weight:700;letter-spacing:3px;text-transform:uppercase;color:var(--gold);margin-bottom:18px}
    .cta-h2{font-size:clamp(1.85rem,4.5vw,3.25rem);font-weight:900;letter-spacing:-.03em;color:#fff;max-width:640px;margin:0 auto 14px;line-height:1.1}
    .cta-sub{font-size:1.0625rem;color:rgba(255,255,255,.55);max-width:420px;margin:0 auto 36px}
    .cta-acts{display:flex;gap:10px;justify-content:center;flex-wrap:wrap}

    /* ═══ FOOTER ═══ */
    #footer{background:var(--navy);color:#fff;padding:60px 0 36px;border-top:1px solid rgba(255,255,255,.06)}
    .foot-grid{display:grid;grid-template-columns:2fr 1fr 1fr 1fr;gap:40px;margin-bottom:48px}
    .foot-brand img{height:42px;width:auto;margin-bottom:16px}
    .foot-brand p{font-size:.875rem;color:rgba(255,255,255,.4);line-height:1.75;max-width:270px;margin-bottom:12px}
    .foot-incubated{font-size:11px;color:rgba(255,255,255,.3);letter-spacing:.5px}
    .foot-incubated span{color:rgba(255,255,255,.55);font-weight:600}
    .foot-col h4{font-size:10px;font-weight:700;letter-spacing:2.5px;text-transform:uppercase;color:rgba(255,255,255,.3);margin-bottom:18px}
    .foot-col ul{list-style:none;display:flex;flex-direction:column;gap:10px}
    .foot-col ul a{font-size:.875rem;color:rgba(255,255,255,.55);transition:color .18s}
    .foot-col ul a:hover{color:#fff}
    .foot-btm{border-top:1px solid rgba(255,255,255,.08);padding-top:24px;display:flex;align-items:center;justify-content:space-between;gap:14px;flex-wrap:wrap}
    .foot-btm p{font-size:.8125rem;color:rgba(255,255,255,.28)}
    .foot-contact{font-size:.8125rem;color:rgba(255,255,255,.4)}
    .foot-contact a{color:var(--gold-lt)}
    @media(max-width:860px){.foot-grid{grid-template-columns:1fr 1fr;gap:32px}}
    @media(max-width:480px){.foot-grid{grid-template-columns:1fr}}

    /* ═══ MODALS ═══ */
    .modal-overlay{position:fixed;inset:0;z-index:1000;background:rgba(10,18,40,.72);backdrop-filter:blur(8px);display:flex;align-items:center;justify-content:center;padding:20px;opacity:0;visibility:hidden;transition:opacity .28s,visibility .28s}
    .modal-overlay.open{opacity:1;visibility:visible}
    .modal-card{background:#fff;border-radius:26px;width:100%;max-width:490px;padding:44px 40px;position:relative;max-height:90vh;overflow-y:auto;transform:translateY(14px);transition:transform .3s var(--ease)}
    .modal-overlay.open .modal-card{transform:none}
    .modal-x{position:absolute;top:16px;right:16px;width:34px;height:34px;border-radius:50%;background:var(--off);border:none;cursor:pointer;display:flex;align-items:center;justify-content:center;font-size:17px;color:var(--muted);transition:all .18s}
    .modal-x:hover{background:var(--g100);color:var(--dark)}
    .modal-h{font-size:1.75rem;font-weight:900;letter-spacing:-.02em;text-align:center;margin-bottom:7px;line-height:1.2}
    .modal-sub{text-align:center;color:var(--muted);font-size:.9375rem;margin-bottom:24px}
    .seg{display:grid;grid-template-columns:1fr 1fr;background:var(--off);border-radius:12px;padding:4px;gap:4px;margin-bottom:24px}
    .seg-btn{padding:10px;border-radius:10px;font-size:.875rem;font-weight:600;background:transparent;color:var(--muted);transition:all .18s}
    .seg-btn.on{background:var(--navy);color:#fff;box-shadow:0 2px 8px rgba(0,0,0,.12)}
    .mform{display:flex;flex-direction:column;gap:16px}
    .ff label{display:block;font-size:.8125rem;font-weight:700;color:var(--dark);margin-bottom:6px}
    .ff input,.ff select,.ff textarea{width:100%;padding:12px 14px;border-radius:10px;background:var(--off);border:1.5px solid transparent;font-family:'Inter',sans-serif;font-size:.9375rem;color:var(--dark);transition:border-color .18s,background .18s;outline:none}
    .ff input:focus,.ff select:focus,.ff textarea:focus{border-color:var(--gold);background:#fff}
    .ff textarea{resize:vertical;min-height:85px}
    .frow{display:grid;grid-template-columns:1fr 1fr;gap:12px}
    .fsubmit{width:100%;padding:14px;border-radius:12px;background:var(--gold);color:#fff;font-size:1rem;font-weight:700;font-family:'Inter',sans-serif;cursor:pointer;border:none;transition:all .2s;margin-top:4px}
    .fsubmit:hover{background:var(--gold-lt);transform:translateY(-2px);box-shadow:0 8px 20px rgba(201,151,42,.3)}
    .fnote{text-align:center;font-size:.8125rem;color:var(--muted);margin-top:3px}
    .msuccess{display:none;flex-direction:column;align-items:center;text-align:center;gap:12px;padding:12px 0}
    .msuccess.show{display:flex}
    .msuccess-icon{width:56px;height:56px;border-radius:50%;background:var(--gold-pl);display:flex;align-items:center;justify-content:center}
    .msuccess-icon svg{width:24px;height:24px;color:var(--gold)}
    .msuccess h3{font-size:1.4rem;font-weight:800}
    .msuccess p{color:var(--muted);max-width:280px}
    @media(max-width:520px){.modal-card{padding:32px 22px}.frow{grid-template-columns:1fr}}

    /* ── Responsive ── */
    @media(max-width:860px){.container{padding:0 24px}.sec{padding:80px 0}}
    @media(max-width:640px){.container{padding:0 18px}#hero{padding:104px 0 72px}.nav-links,.nav-links~.btn{display:none}#hamburger{display:flex}}

    /* ── Mobile refinements (phone sizing, PC view unchanged) ── */
    @media(max-width:640px){
      /* Section vertical padding — all sections */
      .sec{padding:60px 0}
      #story,#impact,#for-students,#cta{padding:60px 0}

      /* Hero — tighten spacing, stack buttons */
      #hero{padding:90px 0 52px}
      .hero-h1{margin-bottom:16px}
      .hero-sub{margin-bottom:24px;font-size:1rem}
      .hero-actions{flex-direction:column;align-items:center;gap:10px}
      .hero-actions .btn{width:100%;max-width:300px;justify-content:center}
      .hero-badge{font-size:9px;letter-spacing:2px;margin-bottom:20px}

      /* Mission pillars — description full-width under title */
      .pillar-row{padding:20px 16px;gap:14px 12px}
      .pillar-icon{width:44px;height:44px;border-radius:10px}
      .pillar-icon svg{width:20px;height:20px}
      .pillar-left h3{font-size:1.1rem}
      .pillar-right{grid-column:1/-1;padding-top:0}

      /* Story — reduce gap when stacked */
      .story-layout{gap:32px}
      .story-card{padding:16px 18px}
      .story-card .sc-num{font-size:1.6rem}

      /* Impact grid — prevent number/label overflow */
      .impact-cell{padding:26px 10px}
      .ic-num{font-size:2.25rem}
      .ic-lbl{font-size:.6rem;letter-spacing:.8px;word-break:break-word;hyphens:auto}

      /* Founders — allow full width, not 320px cap */
      .founders-grid{max-width:none}
      .founders-big-h{font-size:clamp(2.4rem,14vw,4.5rem);line-height:1}

      /* Programs */
      .prog-photo{height:180px}
      .prog-content{padding:22px 20px 26px}
      .prog-tag{font-size:9px}

      /* Scholarships / internships */
      .rc-card{padding:22px 18px}
      .schol-filter{gap:6px}
      .schol-filter button{font-size:.7rem;padding:7px 12px}

      /* Get involved */
      .inv-card{padding:22px 18px}

      /* CTA — plain navy, no photo overlay */
      #cta::before{display:none}
      .cta-acts{flex-direction:column;align-items:center}
      .cta-acts .btn{width:100%;max-width:300px;justify-content:center}
      .cta-h2{font-size:clamp(1.7rem,8vw,2.8rem)}

      /* Footer */
      .foot-btm{flex-direction:column;align-items:flex-start;gap:6px}
    }

    /* ── Performance: skip render of far-below-fold sections ── */
    #scholarships,#for-students,#get-involved{content-visibility:auto;contain-intrinsic-size:0 700px}
